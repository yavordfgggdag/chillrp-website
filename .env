# ========== Supabase — НОВ проект (отделен от стария сайт) ==========
# 1) Създай проект: https://supabase.com/dashboard → New project
# 2) Settings → API: копирай Project URL и anon public key тук (без кавички или с кавички — както предпочиташ)
# 3) CLI: npx supabase login && npx supabase link --project-ref <ref_от_URL>
# 4) SQL: изпълни нужните скриптове от supabase/ (виж supabase/README_SQL_SCRIPTS.md ако има)
# 5) Auth → Discord: Redirect URL = https://<твоят-ref>.supabase.co/auth/v1/callback

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# По избор (legacy ключ в някои скриптове)
# VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_PROJECT_ID=

SUPABASE_URL=
SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   # само за локални функции / не в Git

VITE_DEV_BYPASS_ROLES=true

VITE_UPLOAD_MAX_FILE_SIZE_MB=10
VITE_UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/avif,video/mp4,video/webm

VITE_LOG_ACTIVITY_DEV=true

# Edge Functions secrets — само в Supabase Dashboard (не тук): DISCORD_BOT_TOKEN, DISCORD_GUILD_ID, SITE_URL, …
# Пълен списък: .env.example

VITE_PAYPAL_ME_HANDLE=fraisaaa
VITE_REVOLUT_IBAN=LT333250017244090570
