################################################################################
# ОБЯЗАТЕЛНО: Копирай като .env и попълни стойностите.
# Този репо е за ОТДЕЛЕН сайт — създай НОВ проект в https://supabase.com/dashboard
# (не ползвай project ref / ключове от друг сайт).
################################################################################

################################################################################
# Supabase Client (Frontend)
################################################################################

# Project URL — Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# Anon public key — същата страница (legacy: VITE_SUPABASE_PUBLISHABLE_KEY)
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Опционално: същият ref като в URL (за документация/скриптове)
# VITE_SUPABASE_PROJECT_ID="your-project-ref"

# Публичен URL на сайта — ЗАДЪЛЖИТЕЛЕН за production билд (Vercel/Netlify env). Същият като SITE_URL в Supabase Edge secrets.
# Без него fallback е localhost и OAuth/линкове могат да сочат грешно.
# При нов домейн: същият каноничен URL тук + в Supabase → Auth → Redirect URLs → https://ТВОЙ-ДОМЕЙН/auth/callback
# + Supabase Edge secret SITE_URL (chillbot, плащания) и Discord Developer → OAuth2 Redirect към Supabase callback.
# VITE_SITE_URL="https://www.твоят-домейн.com"

# Публично име (hero / footer)
# VITE_SITE_NAME="TLR RP"

# Java сървър адрес и версия за началната страница
# VITE_MINECRAFT_SERVER_ADDRESS="play.example.net"
# VITE_MINECRAFT_VERSION="1.21+"

# Опционално: Discord покана (по подразбиране в кода е https://discord.gg/uqAdjz6SbQ)
# VITE_DISCORD_INVITE="https://discord.gg/uqAdjz6SbQ"
# Магазин: при „Купи“ / количка се отваря този линк (напр. канал за тикети). Празно = поканата горе.
# VITE_DISCORD_SHOP_CHECKOUT_URL="https://discord.com/channels/GUILD_ID/CHANNEL_ID"

# Legacy (ако някъде вече си го ползвал). Може да го махнеш.
# VITE_SUPABASE_PUBLISHABLE_KEY="your-public-anon-key"


################################################################################
# Supabase Server (Backend / Edge Functions ONLY)
################################################################################

# Service role key (NEVER expose in the browser or bundle).
# Use only in secure server-side environments (Supabase Edge Functions, server runtimes).
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# JWT secret used by Supabase for auth token verification (server-side only).
SUPABASE_JWT_SECRET="your-jwt-secret"


################################################################################
# Security / Rate Limiting
################################################################################

# Maximum upload size (in MB) enforced client-side before uploading to Supabase Storage.
# За видео в галерията на продукти препоръчително 100–200+ (и провери лимита на bucket в Supabase).
UPLOAD_MAX_FILE_SIZE_MB=150
VITE_UPLOAD_MAX_FILE_SIZE_MB=150

# Allowed mime types for media uploads (comma-separated, checked client-side).
# Включва снимки, видео клипове и MP3/аудио за галерия на продукти.
UPLOAD_ALLOWED_MIME_TYPES="image/jpeg,image/png,image/webp,image/avif,image/gif,video/mp4,video/webm,video/quicktime,video/ogg,video/x-matroska,audio/mpeg,audio/mp3,audio/mp4,audio/wav,audio/ogg"
VITE_UPLOAD_ALLOWED_MIME_TYPES="image/jpeg,image/png,image/webp,image/avif,image/gif,video/mp4,video/webm,video/quicktime,video/ogg,video/x-matroska,audio/mpeg,audio/mp3,audio/mp4,audio/wav,audio/ogg"

# Login rate limiting (client-side throttling around Supabase auth).
# Maximum failed login attempts within the window below.
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
VITE_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5

# Time window (in seconds) for counting failed login attempts.
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
VITE_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300


################################################################################
# FiveM / CFX (опционално — по подразбиране е cfx.re/join/4oqxj8 в кода)
################################################################################

# VITE_FIVEM_CFX_JOIN_URL="https://cfx.re/join/4oqxj8"


################################################################################
# Discord (бот, сървър, webhooks, полиция)
################################################################################

# В Supabase: Edge Functions > log-activity > Secrets → добави:
# DISCORD_ACTIVITY_LOG_WEBHOOK_URL = URL на Discord webhook за канал за активност (запис на посещения, логин, магазин, ганг кандидатури и т.н.)

# Опционално: тест на Discord записа от localhost преди пускане на сайта.
# Задай VITE_LOG_ACTIVITY_DEV=true в .env и рестартирай dev сървъра; после отвори localhost и навигирай – събитията ще отиват в web_logs и в Discord.
# VITE_LOG_ACTIVITY_DEV=false

# Админ панел без Discord staff роля: при `npm run dev` вече е отворен (import.meta.env.DEV).
# За `vite preview` или друг билд на LAN, ако трябва същото поведение: VITE_LOCAL_ADMIN_BYPASS=true
# VITE_LOCAL_ADMIN_BYPASS=false

# Bot token за Discord API (използва се от edge functions: notify-discord-*, check-discord-member, check-police-role).
DISCORD_BOT_TOKEN="your-discord-bot-token"

# Guild (сървър) ID за проверки и известия.
DISCORD_GUILD_ID="1471238721096646718"

# В Supabase Edge Functions → Secrets (функция notify-shop-ticket-code):
# Webhook към staff канал — при генериране на код за тикет от магазина (код + продукт + Discord име).
# DISCORD_SHOP_TICKET_LOG_WEBHOOK_URL="https://discord.com/api/webhooks/..."
#
# Ботът пише в канал + @роля (по подразбиране в кода: канал 1490776676462756042, роля 1471238721566146796).
# Презапиши с env ако смениш канал/роля:
# DISCORD_SHOP_TICKET_CHANNEL_ID="1490776676462756042"
# DISCORD_SHOP_TICKET_PING_ROLE_ID="1471238721566146796"

# sync-staff-from-discord: опционално 7 role ID-та (SUPPORT TEAM→OWNER), запетая — ако Discord имената не съвпадат с етикетите.
# DISCORD_STAFF_ROLE_IDS="id1,id2,id3,id4,id5,id6,id7"

# set-citizenid-from-game: споделен секрет с FiveM сървъра (HTTP header x-chillrp-game-secret).
# CHILLRP_GAME_CITIZEN_LINK_SECRET="дълъг-случаен-низ"

# За /police — проверка за роля „Полицай“ (по подразбиране са тези IDs).
# DISCORD_POLICE_GUILD_ID="1471238721096646718"
# DISCORD_POLICE_ROLE_ID="1471238721515819110"

# В Supabase Dashboard > Authentication > Providers трябва да е включен Discord
# и да са попълнени Discord Application Client ID и Client Secret. Redirect URL в Discord
# приложението: https://<project-ref>.supabase.co/auth/v1/callback
#
# Бот „да те добави в сървъра“: deploy на Edge Function add-discord-guild-member; ботът в Discord
# трябва да има права за добавяне на членове; OAuth scope guilds.join се заявява автоматично от сайта.
#
# За chillbot (Edge): опционално същият адрес като на сайта за Java сървъра (или ползвай site_settings minecraft_server_address)
# MINECRAFT_SERVER_ADDRESS="play.example.net"


################################################################################
# Магазин: Revolut / Stripe
################################################################################

# revolut (по подразбиране) | stripe | both
# VITE_SHOP_PAYMENT=revolut

# За бутон „Revolut / PayPal“ трябва ПОНЕ ЕДНО от двете по-долу (и рестарт на npm run dev).
# IBAN за превод (Revolut Business и т.н.) — публично на сайта
# VITE_REVOLUT_IBAN=BG00UNCR70001512345678
# VITE_REVOLUT_BIC=UNCRBGSF
# VITE_REVOLUT_BENEFICIARY=TLR
#
# Локален UI тест без реална сметка (мин. 8 знака; подмени преди production):
# VITE_REVOLUT_IBAN=BG00DEV0000000000

# PayPal.me потребителско име (само handle, без URL) — ръчно плащане със същата „бележка“ шаблон като при IBAN
# VITE_PAYPAL_ME_HANDLE=TLRShop

################################################################################
# Stripe (плащания в магазина)
################################################################################

# Secret key от Stripe Dashboard (Developers > API keys). Използва се САМО в Supabase Edge Function Secrets, НЕ в .env на фронтенда.
# В Supabase: Project > Edge Functions > create-payment > Secrets → добави STRIPE_SECRET_KEY = sk_live_... или sk_test_...
# STRIPE_SECRET_KEY="sk_test_..."

# За production: задай в Supabase Edge Function Secrets. Нужен е за Stripe success_url/cancel_url.
# SITE_URL="https://tvoiat-domain.com"

# Webhook за автоматично op-crime GC (функция stripe-webhook-opcrime-gc). Само в Supabase Secrets, не във Vite .env
# STRIPE_WEBHOOK_SIGNING_SECRET="whsec_..."
# SUPABASE_SERVICE_ROLE_KEY — само за Edge функция stripe-webhook-opcrime-gc (чете profiles / deliveries)
# OPCRIME_GC_DELIVERY_URL / OPCRIME_GC_DELIVERY_SECRET — опционално: твой HTTPS приемник → RCON opcrime_store
# CHILLRP_STORE_REDEEM_SECRET — същата стойност в FiveM server.cfg (setr chillrp_redeem_secret). Edge: redeem-store-purchase
# STORE_REDEEM_COMMAND_TEMPLATE — опционално в Secrets за stripe-webhook-opcrime-gc + notify-discord-purchase контекст; по подразбиране: /chillrp_redeem {CODE}
# Изпълни supabase/RUN_THIS_stripe_buyer_dm_idempotent.sql (или миграцията) за таблица stripe_checkout_buyer_dm_sent — един DM на поръчка при Stripe retry.
# Виж STRIPE_SETUP.md §7, docs/INTEGRATION_CHECKLIST.md, supabase/RUN_THIS_opcrime_gc_shop.sql, RUN_THIS_store_redeem_flow.sql


################################################################################
# Minecraft — Paper плъгин „TLR Shop Delivery“ (Edge: minecraft-shop-claim)
################################################################################
#
# В Supabase → Edge Functions → minecraft-shop-claim → Secrets:
# MC_SHOP_CLAIM_SECRET="дълъг-случаен-низ"
# (същата стойност в plugins/TlrShopDelivery/config.yml на Java сървъра)
#
# URL за плъгина: https://<project-ref>.supabase.co/functions/v1/minecraft-shop-claim


################################################################################
# Media / Storage
################################################################################

# Primary Supabase Storage bucket for user-uploaded media.
MEDIA_BUCKET_ID="uploads"

# Whether newly uploaded media should be public by default.
# (The actual access control is enforced via RLS and media_assets.is_public.)
MEDIA_DEFAULT_PUBLIC=false


################################################################################
# Начална страница — Sneak peek (YouTube)
################################################################################

# Опционално: YouTube линкове за секцията „Sneak Peek“, разделени със запетая.
# Допълва src/lib/homeSneakPeekVideos.ts и Admin → Настройки → sneak_peek_urls.
# VITE_HOME_SNEAK_PEEK_URLS="https://www.youtube.com/watch?v=VIDEO_ID1,https://youtu.be/VIDEO_ID2"

################################################################################
# Analytics / Tracking (injected via admin-configured settings)
################################################################################

# Optional: default analytics snippets that can be overridden via the admin panel.
# These are NOT injected directly; they are read and stored securely in the DB.
DEFAULT_ANALYTICS_HEAD_SNIPPET=""
DEFAULT_ANALYTICS_BODY_SNIPPET=""

